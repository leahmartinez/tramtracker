# GTFS-Realtime Trip Updates feed for Yarra Trams
GTFS_RT_URL=https://api.opendata.transport.vic.gov.au/opendata/public-transport/gtfs/realtime/v1/tram/trip-updates

# API key from opendata.transport.vic.gov.au (under API tokens) — sent as KeyID header
GTFS_RT_KEY=your_api_key_here

# Static GTFS zip download URL (Yarra Trams)
GTFS_STATIC_URL=https://opendata.transport.vic.gov.au/...

# Port the server listens on
PORT=3000
